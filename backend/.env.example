# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg2://portfolio_app:portfolio_dev_password@localhost:5432/portfolio_contact

# Comma-separated list of origins allowed to call this API
ALLOWED_ORIGINS=http://localhost:5173

# Secret key required in the X-Admin-Key header to read /api/messages
ADMIN_API_KEY=change-me-to-a-long-random-value

# OpenAI API key used by NOVA's /api/ask endpoint (gpt-4o-mini)
OPENAI_API_KEY=
